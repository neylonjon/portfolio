---
import type { GitHubData } from "../lib/github";
import ContributionGraph from "./ContributionGraph.astro";
import CommitsTicker from "./CommitsTicker.astro";

interface Props {
  data: GitHubData;
}
const { data } = Astro.props;

function formatSync(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const min = Math.floor(diff / 60000);
  if (min < 1) return "just now";
  if (min < 60) return `${min}m ago`;
  const hr = Math.floor(min / 60);
  return `${hr}h ago`;
}
---

<section id="now" class="container-wide py-12 md:py-16 hairline-b">
  <header class="flex items-baseline justify-between mb-8 gap-4 flex-wrap">
    <span class="section-label">now</span>
    <span class="mono text-[11px] text-[color:var(--color-faint)] tabular-nums">
      {data.source === "live" ? "live" : "cached"} · {data.accounts.length} account{data.accounts.length === 1 ? "" : "s"} · synced {formatSync(data.syncedAt)}
    </span>
  </header>
  {data.accounts.length > 0 && (
    <p class="mono text-[10px] text-[color:var(--color-faint)] mb-6 tracking-[0.06em]" aria-label="Tracked GitHub accounts">
      {data.accounts.map((a, i) => (
        <>
          <a href={`https://github.com/${a}`} target="_blank" rel="noopener" class="!border-none hover:text-[color:var(--color-accent)]">@{a}</a>
          {i < data.accounts.length - 1 && <span class="text-[color:var(--color-faint)]"> · </span>}
        </>
      ))}
    </p>
  )}

  <div class="now-grid">
    <div class="commits-pane">
      <h2 class="mono text-[11px] uppercase tracking-[0.12em] text-[color:var(--color-muted)] mb-3">
        latest commits
      </h2>
      {data.commits.length === 0 ? (
        <p class="empty-state mono">
          awaiting first sync. github token not yet configured.
        </p>
      ) : (
        <CommitsTicker commits={data.commits} />
      )}
    </div>

    <div class="graph-pane">
      <h2 class="mono text-[11px] uppercase tracking-[0.12em] text-[color:var(--color-muted)] mb-3">
        cadence · 26w
      </h2>
      <ContributionGraph weeks={data.contributions} total={data.totalContributions} />
    </div>
  </div>
</section>

<style>
  .now-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }
  .empty-state {
    font-size: 12px;
    color: var(--color-faint);
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
    padding: 14px 0;
    letter-spacing: 0.04em;
  }
  @media (max-width: 900px) {
    .now-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
