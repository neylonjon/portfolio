---
const buildVersion = "V0.2.0";
const buildDate = new Date().toISOString().slice(0, 10);
---

<footer class="hairline hairline-sweep hairline-sweep-top mt-24" style="--hair-sweep-delay: 4.6s;">
  <div
    class="flex flex-col sm:flex-row items-center justify-between gap-4"
    style="padding: 24px 48px 36px;"
  >
    <p
      class="mono flex items-center gap-3"
      style="font-size: 10px; letter-spacing: 0.1em; color: var(--color-muted);"
    >
      <span
        aria-hidden="true"
        style="display: inline-block; width: 10px; height: 10px; background: var(--color-accent); transform: rotate(45deg);"
      ></span>
      <span>© 2026 JON NEYLON · NEXTWORK · AUSTIN, TX · CT</span>
    </p>

    <p
      class="mono tabular-nums"
      style="font-size: 10px; letter-spacing: 0.1em; color: var(--color-muted);"
      aria-label={`Build ${buildVersion} dated ${buildDate}`}
    >
      {buildVersion} · {buildDate}
    </p>

    <a
      href="#main"
      class="!border-none"
      style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 8px 14px; border: 1px solid var(--color-hairline) !important; border-radius: 9999px; font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-fg); text-decoration: none;"
    >
      <span aria-hidden="true">↑</span> TOP
    </a>
  </div>
</footer>
