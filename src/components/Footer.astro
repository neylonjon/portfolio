---
const buildVersion = "V0.2.0";
const buildDate = new Date().toISOString().slice(0, 10);
---

<footer class="hairline hairline-sweep hairline-sweep-top mt-24 footer-band" style="--hair-sweep-delay: 4.6s;">
  <div class="footer-credit-row">
    <p
      class="mono flex items-center gap-3"
      style="font-size: 10px; letter-spacing: 0.1em; color: rgba(17, 17, 17, 0.75);"
    >
      <span
        aria-hidden="true"
        style="display: inline-block; width: 10px; height: 10px; background: #111111; transform: rotate(45deg);"
      ></span>
      <span>© 2026 JON NEYLON · NEXTWORK · AUSTIN, TX · CT</span>
    </p>

    <p
      class="mono tabular-nums"
      style="font-size: 10px; letter-spacing: 0.1em; color: rgba(17, 17, 17, 0.75);"
      aria-label={`Build ${buildVersion} dated ${buildDate}`}
    >
      {buildVersion} · {buildDate}
    </p>

    <a
      href="#main"
      class="!border-none footer-top-btn"
    >
      <span aria-hidden="true">↑</span> TOP
    </a>
  </div>

  <div class="footer-wordmark-wrap" aria-hidden="true">
    <span class="footer-wordmark">Neylon</span>
  </div>
</footer>

<style>
  .footer-band {
    background: var(--color-accent);
    color: #111111;
    overflow: hidden;
    padding-bottom: 0;
  }
  .footer-credit-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 48px 24px;
    flex-wrap: wrap;
  }
  .footer-top-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 8px 14px;
    border: 1px solid rgba(17, 17, 17, 0.35) !important;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #111111;
    text-decoration: none;
  }
  .footer-wordmark-wrap {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 24px 24px 0;
    margin-top: -8px;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 400;
    color: #111111;
    line-height: 0.82;
    letter-spacing: -0.04em;
    font-size: clamp(120px, 24vw, 320px);
    display: block;
    transform: translateY(8%);
  }
  @media (max-width: 900px) {
    .footer-credit-row {
      padding: 24px 32px 20px;
    }
  }
  @media (max-width: 640px) {
    .footer-credit-row {
      padding: 20px 20px 16px;
      gap: 12px;
      justify-content: flex-start;
    }
    .footer-wordmark {
      font-size: clamp(72px, 28vw, 180px);
    }
  }
</style>
