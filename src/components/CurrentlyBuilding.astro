---
interface Props {
  headline?: string;
  sub?: string;
  lastCommitAgo?: string;
  lastCommitMessage?: string;
}

const {
  headline = "Wiring a halftone shader to my live GitHub feed.",
  sub = "PERSONAL PORTFOLIO · ASTRO 5 + WEBGL · SHIPS TONIGHT",
  lastCommitAgo = "LAST COMMIT · 4M AGO",
  lastCommitMessage = "feat: contribution texture drives dot radius",
} = Astro.props;
---

<article class="cb-tile">
  <header class="cb-head">
    <div class="cb-label-row">
      <span class="cb-diamond" aria-hidden="true"></span>
      <span class="cb-label">CURRENTLY BUILDING</span>
    </div>
    <span class="cb-live-pill" aria-label="Live">
      <span class="cb-live-dot" aria-hidden="true"></span>
      <span class="cb-live-text">LIVE</span>
    </span>
  </header>

  <h2 class="cb-headline">{headline}</h2>
  <p class="cb-sub">{sub}</p>

  <footer class="cb-footer">
    <span class="cb-foot-label">{lastCommitAgo}</span>
    <span class="cb-foot-msg">{lastCommitMessage}</span>
  </footer>
</article>

<style>
  .cb-tile {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: 0;
    padding: 32px 34px;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 60px rgba(255, 106, 61, 0.06);
  }
  .cb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .cb-label-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cb-diamond {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    transform: rotate(45deg);
    display: inline-block;
  }
  .cb-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cb-live-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 106, 61, 0.12);
    border: 1px solid rgba(255, 106, 61, 0.3);
    border-radius: 9999px;
    padding: 4px 10px;
  }
  .cb-live-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(255, 106, 61, 0.6);
  }
  .cb-live-text {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .cb-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    letter-spacing: -0.02em;
    line-height: 40px;
    color: var(--color-fg);
    margin: 22px 0 14px;
  }
  .cb-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }
  .cb-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-hairline);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cb-foot-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cb-foot-msg {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 18px;
    color: var(--color-fg);
  }
  @media (max-width: 900px) {
    .cb-headline {
      font-size: 28px;
      line-height: 32px;
    }
  }
</style>
