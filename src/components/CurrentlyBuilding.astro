---
import TileShader from "./TileShader.tsx";

interface Props {
  headline?: string;
  sub?: string;
  lastCommitAgo?: string;
  lastCommitMessage?: string;
}

const {
  headline = "Wiring a halftone shader to my live GitHub feed.",
  sub = "This site · Astro 5 + WebGL · ships tonight",
  lastCommitAgo = "Last commit · 4m ago",
  lastCommitMessage = "feat: contribution texture drives dot radius",
} = Astro.props;
---

<article class="cb-tile">
  <div class="cb-shader-layer" aria-hidden="true"><TileShader client:load /></div>
  <header class="cb-head">
    <div class="cb-label-row">
      <span class="cb-diamond" aria-hidden="true"></span>
      <span class="cb-label">CURRENTLY BUILDING</span>
    </div>
    <span class="cb-live-pill" aria-label="Live">
      <span class="cb-live-dot" aria-hidden="true"></span>
      <span class="cb-live-text">LIVE</span>
    </span>
  </header>

  <h2 class="cb-headline">{headline}</h2>
  <p class="cb-sub">{sub}</p>

  <footer class="cb-footer">
    <span class="cb-foot-label">{lastCommitAgo}</span>
    <span class="cb-foot-msg">{lastCommitMessage}</span>
  </footer>
</article>

<style>
  /* Animated gradient border via Florian Kiem's @property + dual-background
     technique. An interior fill clips to padding-box; a conic-gradient
     clips to border-box. The transparent border exposes the gradient as
     the ring. The angle animates via @property so the bright orange "beam"
     orbits the perimeter. */
  .cb-tile {
    position: relative;
    background:
      linear-gradient(var(--color-bg-elevated), var(--color-bg-elevated)) padding-box,
      conic-gradient(
        from var(--cb-border-angle),
        var(--color-hairline) 0%,
        var(--color-hairline) 38%,
        rgba(255, 106, 61, 0.55) 46%,
        var(--color-accent) 50%,
        rgba(255, 106, 61, 0.55) 54%,
        var(--color-hairline) 62%,
        var(--color-hairline) 100%
      ) border-box;
    border: 1px solid transparent;
    border-radius: 0;
    padding: 32px 34px;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 60px rgba(255, 106, 61, 0.06);
    animation: cb-rotate-border 8s linear infinite;
    transition: box-shadow 280ms var(--ease-out-quart),
                animation-duration 280ms ease;
  }
  /* Halftone overlay layer. Subtly always-on at ~0.45 so the featured
     tile carries texture even before interaction, brightens to 0.85
     on hover. The TileShader React island paints a WebGL Dithering
     canvas; this wrapper handles positioning + opacity transitions. */
  .cb-shader-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.45;
    transition: opacity 350ms var(--ease-out-quart);
    pointer-events: none;
  }
  .cb-tile > :not(.cb-shader-layer) {
    position: relative;
    z-index: 1;
  }
  @media (hover: hover) {
    .cb-tile:hover {
      animation-duration: 2.4s;
      box-shadow:
        0 24px 48px rgba(0, 0, 0, 0.45),
        0 0 80px rgba(255, 106, 61, 0.22),
        0 0 0 1px rgba(255, 106, 61, 0.18);
    }
    .cb-tile:hover .cb-shader-layer {
      opacity: 0.85;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cb-tile {
      animation: none;
      background:
        linear-gradient(var(--color-bg-elevated), var(--color-bg-elevated)) padding-box,
        linear-gradient(var(--color-hairline), var(--color-hairline)) border-box;
    }
  }
  .cb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .cb-label-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cb-diamond {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    transform: rotate(45deg);
    display: inline-block;
  }
  .cb-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cb-live-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 106, 61, 0.12);
    border: 1px solid rgba(255, 106, 61, 0.3);
    border-radius: 9999px;
    padding: 4px 10px;
  }
  .cb-live-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(255, 106, 61, 0.6);
  }
  .cb-live-text {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .cb-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    letter-spacing: -0.02em;
    line-height: 40px;
    color: var(--color-fg);
    margin: 22px 0 14px;
  }
  .cb-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }
  .cb-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-hairline);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cb-foot-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cb-foot-msg {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 18px;
    color: var(--color-fg);
  }
  @media (max-width: 900px) {
    .cb-tile {
      padding: 24px 26px;
    }
    .cb-headline {
      font-size: 28px;
      line-height: 32px;
      margin: 18px 0 12px;
    }
  }
  @media (max-width: 640px) {
    .cb-tile {
      padding: 20px 22px;
    }
    .cb-headline {
      font-size: 24px;
      line-height: 28px;
    }
    .cb-foot-msg {
      font-size: 12px;
    }
  }
</style>
