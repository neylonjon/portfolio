---
import type { ContributionWeek } from "../lib/github";

interface Props {
  weeks: ContributionWeek[];
  total: number;
  rangeWeeks?: number;
}

const { weeks, total, rangeWeeks = 12 } = Astro.props;

// 5 opacity steps mapped against the warm orange accent.
// Level 0 is a tinted not-pure-black so the grid stays visible on dark bg.
const LEVEL_BG: Record<number, string> = {
  0: "rgba(255,106,61,0.06)",
  1: "rgba(255,106,61,0.18)",
  2: "rgba(255,106,61,0.40)",
  3: "rgba(255,106,61,0.65)",
  4: "#FF6A3D",
};

const YELLOW_THRESHOLD = 15;

const trimmed = weeks.slice(-rangeWeeks);
const totalFormatted = total.toLocaleString();
---

<figure
  class="contribution-graph"
  role="img"
  aria-label={`${totalFormatted} contributions in the last year`}
>
  <div class="grid" aria-hidden="true">
    {trimmed.map((week, wi) => (
      <div class="col">
        {week.days.map((day) => {
          const bg = day.count > YELLOW_THRESHOLD ? "#FFF247" : LEVEL_BG[day.level];
          return (
            <span
              class={`cell level-${day.level} ${wi < Math.floor(rangeWeeks / 2.5) ? "is-old" : ""}`}
              style={`background:${bg}`}
              data-date={day.date}
              data-count={day.count}
              title={`${day.count} contribution${day.count === 1 ? "" : "s"} on ${day.date}`}
            />
          );
        })}
      </div>
    ))}
  </div>
</figure>

<style>
  .contribution-graph {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .grid {
    display: flex;
    gap: 4px;
    overflow: hidden;
  }
  .col {
    display: grid;
    grid-template-rows: repeat(7, 18px);
    gap: 4px;
    flex-shrink: 0;
  }
  .cell {
    width: 18px;
    height: 18px;
    border-radius: 0;
    transition: opacity 200ms ease;
  }
  @media (max-width: 900px) {
    .col { grid-template-rows: repeat(7, 14px); gap: 3px; }
    .cell { width: 14px; height: 14px; }
    .grid { gap: 3px; }
    .is-old { display: none; }
  }
  @media (max-width: 480px) {
    .col { grid-template-rows: repeat(7, 12px); }
    .cell { width: 12px; height: 12px; }
  }
</style>
