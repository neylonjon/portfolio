---
import TileShader from "./TileShader.tsx";

interface Props {
  available?: boolean;
  message?: string;
  replyTime?: string;
}

const {
  available = true,
  message = "Shipping at NextWork · open to chats",
  replyTime = "≤ 24h · CT",
} = Astro.props;
---

<article class="st-tile" data-available={available}>
  <div class="st-shader-layer" aria-hidden="true"><TileShader client:load /></div>
  <div class="st-left">
    <span class="st-dot" aria-hidden="true"></span>
    <div class="st-text">
      <span class="st-label">STATUS</span>
      <span class="st-message">{message}</span>
    </div>
  </div>
  <div class="st-right">
    <span class="st-label">REPLY TIME</span>
    <span class="st-reply">{replyTime}</span>
    <a
      class="st-book"
      href="https://cal.com/jon-neylon/30min"
      target="_blank"
      rel="noopener"
      aria-label="Book a 30 minute chat"
    >Book 30m →</a>
  </div>
</article>

<style>
  .st-tile {
    position: relative;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: 0;
    padding: 20px 28px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100%;
    gap: 16px;
    overflow: hidden;
    transition: box-shadow 280ms var(--ease-out-quart),
                border-color 280ms var(--ease-out-quart);
  }
  .st-shader-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 350ms var(--ease-out-quart);
    pointer-events: none;
  }
  .st-tile > :not(.st-shader-layer) {
    position: relative;
    z-index: 1;
  }
  @media (hover: hover) {
    .st-tile:hover {
      border-color: rgba(255, 106, 61, 0.4);
      box-shadow:
        0 24px 48px rgba(0, 0, 0, 0.45),
        0 0 60px rgba(255, 106, 61, 0.20),
        0 0 0 1px rgba(255, 106, 61, 0.16);
    }
    .st-tile:hover .st-shader-layer {
      opacity: 0.7;
    }
  }
  .st-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .st-dot {
    width: 10px;
    height: 10px;
    border-radius: 9999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(255, 106, 61, 0.2);
    flex-shrink: 0;
  }
  .st-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .st-right {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
    text-align: right;
  }
  .st-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .st-message {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    line-height: 1.1;
  }
  .st-reply {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-fg);
  }
  .st-book {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    border: none;
    transition: opacity 160ms ease;
  }
  .st-book:hover {
    opacity: 0.7;
  }
  @media (max-width: 640px) {
    .st-tile {
      padding: 18px 20px;
    }
    .st-message {
      font-size: 18px;
    }
  }
</style>
