---
// HeroAura. Decorative orange aurora behind the hero headline.
// Pure CSS layered radial gradients with blur, animating background-position
// over a long ease-in-out infinite loop. Pointer-events disabled so it never
// intercepts clicks. Honors prefers-reduced-motion by freezing on a single
// frame.
---

<div class="hero-aura" aria-hidden="true">
  <div class="hero-aura__layer hero-aura__layer--a"></div>
  <div class="hero-aura__layer hero-aura__layer--b"></div>
  <div class="hero-aura__grain"></div>
</div>

<style>
  .hero-aura {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    /* Contain layout/paint so blurred children don't trigger
       composite work on ancestor scrolls. */
    contain: layout paint;
    isolation: isolate;
  }

  .hero-aura__layer {
    position: absolute;
    inset: -20%;
    /* Cap blur at 60px per Emil's note. Acceptable for a one-off
       decorative hero element. */
    filter: blur(60px);
    opacity: 0.55;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .hero-aura__layer--a {
    background:
      radial-gradient(
        38% 42% at 22% 60%,
        rgba(255, 106, 61, 0.55) 0%,
        rgba(255, 106, 61, 0) 70%
      ),
      radial-gradient(
        30% 36% at 70% 30%,
        rgba(255, 242, 71, 0.18) 0%,
        rgba(255, 242, 71, 0) 65%
      );
    animation: aura-drift-a 22s ease-in-out infinite alternate;
  }

  .hero-aura__layer--b {
    background:
      radial-gradient(
        34% 40% at 78% 70%,
        rgba(255, 106, 61, 0.38) 0%,
        rgba(255, 106, 61, 0) 70%
      ),
      radial-gradient(
        24% 30% at 18% 18%,
        rgba(255, 106, 61, 0.22) 0%,
        rgba(255, 106, 61, 0) 70%
      );
    opacity: 0.45;
    animation: aura-drift-b 28s ease-in-out infinite alternate;
  }

  /* Subtle film grain to keep the aura from looking like a default CSS
     gradient. Static, no animation. */
  .hero-aura__grain {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }

  @keyframes aura-drift-a {
    0% {
      transform: translate3d(-6%, -3%, 0) scale(1);
      opacity: 0.5;
    }
    100% {
      transform: translate3d(6%, 4%, 0) scale(1.08);
      opacity: 0.62;
    }
  }

  @keyframes aura-drift-b {
    0% {
      transform: translate3d(5%, 4%, 0) scale(1.05);
      opacity: 0.4;
    }
    100% {
      transform: translate3d(-5%, -3%, 0) scale(1);
      opacity: 0.5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-aura__layer--a,
    .hero-aura__layer--b {
      animation: none;
    }
  }
</style>
