---
interface Props {
  accounts: string[];
}

const { accounts } = Astro.props;

// Hardcoded estimate commit counts for v1. Wire to real data later.
const COMMIT_ESTIMATES: Record<string, string> = {
  jonneylon: "643",
  neylonjon: "412",
  jonnext: "229",
};

// Per-account dot color, matching CommitsTicker mapping.
const DOT_COLOR: Record<string, string> = {
  jonneylon: "#FF6A3D",
  neylonjon: "#FFF247",
  jonnext: "#D4D4D8",
};

const padded = accounts.length.toString().padStart(3, "0");
---

<article class="at-tile">
  <header class="at-head">
    <div class="at-label-row">
      <span class="at-diamond" aria-hidden="true"></span>
      <span class="at-label">ACCOUNTS LINKED</span>
    </div>
    <span class="at-count">{padded}</span>
  </header>

  <ul class="at-list" role="list">
    {accounts.map((a) => (
      <li class="at-row">
        <span class="at-row-left">
          <span
            class="at-dot"
            style={`background:${DOT_COLOR[a] ?? "#D4D4D8"}`}
            aria-hidden="true"
          ></span>
          <a
            href={`https://github.com/${a}`}
            target="_blank"
            rel="noopener"
            class="at-name"
          >{a}</a>
        </span>
        <span class="at-commits tabular-nums">{COMMIT_ESTIMATES[a] ?? "···"}</span>
      </li>
    ))}
  </ul>
</article>

<style>
  .at-tile {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }
  .at-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .at-label-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .at-diamond {
    width: 8px;
    height: 8px;
    background: var(--color-accent-yellow);
    transform: rotate(45deg);
    display: inline-block;
  }
  .at-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .at-count {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    color: var(--color-fg);
    line-height: 1;
  }
  .at-list {
    list-style: none;
    margin: auto 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .at-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-top: 1px solid var(--color-hairline);
  }
  .at-row-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .at-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    display: inline-block;
  }
  .at-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.025em;
    color: var(--color-fg);
    text-decoration: none;
    border: none;
    transition: color 160ms ease;
  }
  .at-name:hover {
    color: var(--color-accent);
  }
  .at-commits {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.025em;
    color: var(--color-muted);
  }
</style>
