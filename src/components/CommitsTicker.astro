---
import type { Commit } from "../lib/github";

interface Props {
  commits: Commit[];
}

const { commits } = Astro.props;

function relativeTime(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const min = Math.floor(diff / 60000);
  if (min < 1) return "NOW";
  if (min < 60) return `${min}M`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr}H`;
  const d = Math.floor(hr / 24);
  if (d < 7) return `${d}D`;
  const w = Math.floor(d / 7);
  if (w < 5) return `${w}W`;
  const mo = Math.floor(d / 30);
  return `${mo}MO`;
}

function shortRepo(full: string) {
  const parts = full.split("/");
  return parts[parts.length - 1] ?? full;
}

// Account dot palette. Falls back to faint grey for unknown logins.
const DOT_COLOR: Record<string, string> = {
  jonneylon: "#FF6A3D",
  neylonjon: "#FFF247",
  jonnext: "#D4D4D8",
};

// Parse a trailing "#NN" or "(#NN)" PR number from a commit message.
function prBadge(message: string): string | null {
  const m = message.match(/#(\d{1,5})\b/);
  return m ? `#${m[1]}` : null;
}
---

<ul class="commits" role="list" aria-label="Recent commits">
  {commits.map((c, idx) => {
    const isLead = idx === 0;
    const dot = DOT_COLOR[c.account] ?? "#71717A";
    const badge = prBadge(c.message);
    return (
      <li class={`row ${isLead ? "row-lead" : ""}`}>
        <a href={c.url} target="_blank" rel="noopener" class="row-link">
          <span class="time mono tabular-nums" aria-label={c.date}>{relativeTime(c.date)}</span>
          <span class="dot" style={`background:${dot}`} aria-hidden="true"></span>
          <span class="body">
            <span class="repo mono">{shortRepo(c.repo)}</span>
            <span class="msg">{c.message}</span>
          </span>
          {badge && <span class="badge mono">{badge}</span>}
        </a>
      </li>
    );
  })}
</ul>

<style>
  .commits {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .row {
    border-bottom: 1px solid var(--color-hairline);
  }
  .row-lead {
    background: rgba(255, 106, 61, 0.05);
  }
  .row-link {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    padding: 16px 28px;
    color: inherit;
    text-decoration: none;
    border: none;
    transition: background 160ms ease;
  }
  .row-link:hover {
    background: rgba(255, 106, 61, 0.04);
  }
  .row-lead .row-link:hover {
    background: rgba(255, 106, 61, 0.08);
  }
  .time {
    width: 48px;
    flex-shrink: 0;
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .row-lead .time {
    color: var(--color-accent);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-grow: 1;
    min-width: 0;
  }
  .repo {
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .msg {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 13px;
    color: var(--color-fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.35;
  }
  .badge {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    flex-shrink: 0;
    align-self: flex-start;
    padding-top: 2px;
  }
  @media (max-width: 768px) {
    .row-link {
      padding: 14px 20px;
      gap: 10px;
    }
    .time {
      width: 40px;
    }
    .msg {
      white-space: normal;
    }
  }
</style>
