---
import type { Commit } from "../lib/github";

interface Props {
  commits: Commit[];
}

const { commits } = Astro.props;

function relativeTime(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const min = Math.floor(diff / 60000);
  if (min < 1) return "just now";
  if (min < 60) return `${min}m`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr}h`;
  const d = Math.floor(hr / 24);
  if (d < 7) return `${d}d`;
  const w = Math.floor(d / 7);
  if (w < 5) return `${w}w`;
  const mo = Math.floor(d / 30);
  return `${mo}mo`;
}

function shortRepo(full: string) {
  const parts = full.split("/");
  return parts[parts.length - 1] ?? full;
}
---

<ul class="commits" role="list" aria-label="Recent commits">
  {commits.map((c) => (
    <li class="row">
      <a href={c.url} target="_blank" rel="noopener" class="row-link !border-none">
        <span class="mono sha tabular-nums" aria-hidden="true">{c.sha}</span>
        <span class="repo mono">{shortRepo(c.repo)}</span>
        <span class="msg">{c.message}</span>
        <span class="mono time tabular-nums" aria-label={c.date}>{relativeTime(c.date)}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .commits {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-hairline);
  }
  .row {
    border-bottom: 1px solid var(--color-hairline);
  }
  .row-link {
    display: grid;
    grid-template-columns: 64px 140px 1fr 48px;
    gap: 12px;
    align-items: baseline;
    padding: 10px 0;
    color: inherit;
    font-size: 13px;
    transition: background 160ms ease;
  }
  .row-link:hover {
    background: color-mix(in oklab, var(--color-bg-elevated) 70%, transparent);
  }
  .sha {
    color: var(--color-faint);
    font-size: 11px;
    flex-shrink: 0;
  }
  .repo {
    color: var(--color-accent);
    font-size: 11px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .msg {
    color: var(--color-fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .time {
    color: var(--color-muted);
    font-size: 11px;
    text-align: right;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .row-link {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      row-gap: 2px;
    }
    .sha { display: none; }
    .repo { grid-row: 1; grid-column: 1; }
    .time { grid-row: 1; grid-column: 2; }
    .msg {
      grid-row: 2;
      grid-column: 1 / -1;
      white-space: normal;
      line-height: 1.4;
    }
  }
</style>
