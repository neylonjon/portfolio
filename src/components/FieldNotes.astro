---
import { getCollection } from "astro:content";

const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

function fmtDate(d: Date) {
  return d.toISOString().slice(0, 10);
}
---

<section id="notes" class="container-wide py-16 md:py-20 hairline-b">
  <header class="flex items-baseline justify-between mb-8 gap-4">
    <span class="section-label">field notes</span>
    <span class="mono text-[11px] text-[color:var(--color-faint)]">
      {notes.length} entries · last updated {fmtDate(notes[0]?.data.date ?? new Date())}
    </span>
  </header>

  <ul class="notes-list" role="list">
    {notes.map((note) => (
      <li class="note">
        <div class="note-row">
          <time class="mono date tabular-nums" datetime={note.data.date.toISOString()}>
            {fmtDate(note.data.date)}
          </time>
          <div class="body">
            <h3 class="title">{note.data.title}</h3>
            <p class="summary">{note.data.summary}</p>
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>

<style>
  .notes-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .note {
    border-top: 1px solid var(--color-hairline);
  }
  .note:last-child {
    border-bottom: 1px solid var(--color-hairline);
  }
  .note-row {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0;
    align-items: baseline;
  }
  .date {
    color: var(--color-faint);
    font-size: 11px;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }
  .body { min-width: 0; }
  .title {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-fg);
    margin: 0 0 6px;
  }
  .summary {
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
  }
  @media (max-width: 640px) {
    .note-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
