---
// Signal section. Left column: pitch + CTAs. Right column: channels card.
// Cal.com URL is a reasonable placeholder; Jon will adjust.
const channels = [
  {
    label: "Email",
    sub: null as string | null,
    value: "jon@nextwork.org",
    valueFont: "sans" as "sans" | "mono",
    right: "Primary →",
    href: "mailto:jon@nextwork.org",
    external: false,
  },
  {
    label: "GitHub",
    sub: "2",
    value: "neylonjon · jonnext",
    valueFont: "mono" as "sans" | "mono",
    right: "Feed →",
    href: "https://github.com/neylonjon",
    external: true,
  },
  {
    label: "X / Twitter",
    sub: null as string | null,
    value: "x.com/neylonjon",
    valueFont: "mono" as "sans" | "mono",
    right: "Live →",
    href: "https://x.com/neylonjon",
    external: true,
  },
  {
    label: "LinkedIn",
    sub: null as string | null,
    value: "linkedin.com/in/jonneylon",
    valueFont: "mono" as "sans" | "mono",
    right: "CV →",
    href: "https://linkedin.com/in/jonneylon",
    external: true,
  },
];
---

<section
  id="signal"
  class="container-wide hairline hairline-sweep hairline-sweep-top signal-section"
  style="--hair-sweep-delay: 2.3s; display: flex; flex-direction: row; gap: 56px; align-items: flex-start; flex-wrap: wrap;"
>
  <div class="signal-pitch" style="max-width: 560px; display: flex; flex-direction: column; gap: 24px;">
    <div class="reveal" style="--reveal-delay: 0ms; display: flex; flex-direction: row; align-items: center; gap: 12px;">
      <span
        aria-hidden="true"
        style="width: 8px; height: 8px; border-radius: 9999px; background: var(--color-accent); flex-shrink: 0;"
      ></span>
      <span
        style="font-family: var(--font-sans); font-weight: 500; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted);"
      >
        Vibes
      </span>
    </div>

    <h2
      class="reveal signal-h2"
      style="--reveal-delay: 80ms; font-family: var(--font-display); font-weight: 400; letter-spacing: -0.025em; color: var(--color-fg); margin: 0;"
    >
      Design + Code + AI agents. Currently Rethinking how we learn online at NextWork.org
    </h2>

    <p
      class="mono"
      style="font-family: var(--font-mono); font-weight: 400; font-size: 11px; letter-spacing: 0.025em; line-height: 19.8px; text-transform: uppercase; color: var(--color-muted); max-width: 480px; margin: 0;"
    >
      Always up for design engineering chats, AI agent talk, or rethinking the systems most people stopped questioning.
    </p>

    <div style="display: flex; flex-direction: row; gap: 10px; padding-top: 12px; flex-wrap: wrap;">
      <a
        href="mailto:jon@nextwork.org"
        style="display: inline-block; background: var(--color-cream); padding: 16px 28px; font-family: var(--font-sans); font-weight: 500; font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-bg); text-decoration: none; clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));"
      >
        Mail → jon@nextwork.org
      </a>

      <a
        href="https://cal.com/jon-neylon/30min"
        target="_blank"
        rel="noopener"
        style="display: inline-block; padding: 16px 24px; font-family: var(--font-sans); font-weight: 500; font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-fg); text-decoration: none; border-bottom: 1px solid rgba(39, 39, 42, 0.6);"
      >
        Book 30m →
      </a>
    </div>
  </div>

  <div
    class="reveal channels-card"
    style="--reveal-delay: 160ms; flex-grow: 1; max-width: 640px; background: var(--color-bg-elevated); border: 1px solid var(--color-hairline); padding: 8px 0;"
  >
    {
      channels.map((c, i) => (
        <a
          href={c.href}
          target={c.external ? "_blank" : undefined}
          rel={c.external ? "noopener" : undefined}
          class="channel-row"
          style={`text-decoration: none; ${i < channels.length - 1 ? "border-bottom: 1px solid var(--color-hairline);" : ""}`}
        >
          <div class="channel-row-left">
            <span
              class="channel-label"
              style="font-family: var(--font-sans); font-weight: 500; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); flex-shrink: 0;"
            >
              {c.label}
              {c.sub && (
                <span style="color: var(--color-muted);"> · {c.sub}</span>
              )}
            </span>
            <span
              class="channel-value"
              style={
                c.valueFont === "sans"
                  ? "font-family: var(--font-sans); font-weight: 400; font-size: 15px; color: var(--color-fg); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                  : "font-family: var(--font-mono); font-weight: 400; font-size: 13px; color: var(--color-fg); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
              }
            >
              {c.value}
            </span>
          </div>
          <span
            style="font-family: var(--font-mono); font-weight: 400; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); flex-shrink: 0;"
          >
            {c.right}
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .signal-section {
    padding: 80px 48px 64px;
  }
  .signal-h2 {
    font-size: 56px;
    line-height: 60px;
  }
  .channel-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 24px;
  }
  .channel-row-left {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    min-width: 0;
    flex: 1;
  }
  .channel-label {
    width: 88px;
  }
  @media (max-width: 900px) {
    .signal-section {
      padding: 56px 32px 48px;
      gap: 32px;
    }
    .signal-h2 {
      font-size: 40px;
      line-height: 44px;
    }
    .channels-card {
      width: 100%;
    }
  }
  @media (max-width: 640px) {
    .signal-section {
      padding: 40px 20px 32px;
    }
    .signal-h2 {
      font-size: 32px;
      line-height: 36px;
    }
    .channel-row {
      padding: 14px 18px;
      gap: 12px;
    }
    .channel-row-left {
      gap: 10px;
    }
    .channel-label {
      width: 72px;
      font-size: 9px;
      letter-spacing: 0.14em;
    }
    .channel-value {
      font-size: 13px !important;
    }
  }
</style>
